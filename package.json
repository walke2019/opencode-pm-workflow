{
  "name": "@walke/opencode-pm-workflow",
  "version": "0.1.9",
  "description": "pm-workflow 的可发布 OpenCode 插件包实现（server + tui + shared package-first implementation）。",
  "type": "module",
  "private": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./index": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./tui": {
      "types": "./dist/tui.d.ts",
      "import": "./dist/tui.js"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "import": "./dist/shared.js"
    }
  },
  "files": [
    "dist",
    "scripts",
    "pm-workflow.schema.json",
    "pm-workflow.config.example.json",
    "README.md",
    "CHANGELOG.md",
    "tsconfig.json",
    "tsconfig.build.json"
  ],
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.22"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "check-auth": "npm whoami",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && node ./node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "typecheck": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "smoke": "node ./scripts/smoke-publish.mjs",
    "pack-dry-run": "node ./scripts/pack-dry-run.mjs",
    "prepare-publish": "npm run typecheck && npm run build",
    "verify-release": "npm run prepare-publish && npm run smoke && npm run pack-dry-run",
    "prepublishOnly": "npm run verify-release"
  },
  "keywords": [
    "opencode",
    "plugin",
    "pm-workflow",
    "workflow"
  ],
  "license": "UNLICENSED"
}
