{
  "$schema": "https://unpkg.com/@walke/opencode-pm-workflow@latest/pm-workflow.schema.json",
  "automation": {
    "mode": "observe"
  },
  "permissions": {
    "allow_execute_tools": true,
    "allow_repair_tools": true,
    "allow_release_actions": false,
    "allow_auto_continue": false
  },
  "confirm": {
    "require_confirm_for_execute": false
  },
  "auto_continue": {
    "enabled": false,
    "max_steps": 3,
    "cooldown_ms": 2000,
    "require_clean_tree": false,
    "stop_on_feedback_signal": true
  },
  "agents": {
    "enabled": true,
    "default_mode": "subagent",
    "dispatch_map": {
      "pm": "pm_lead",
      "plan": "pm_advisor",
      "build": "pm_advisor",
      "commander": "pm_advisor",
      "backend": "pm_backend",
      "frontend": "pm_frontend",
      "qa_engineer": "pm_reviewer",
      "writer": "pm_reviewer",
      "researcher": "pm_researcher"
    },
    "definitions": {
      "pm_lead": {
        "mode": "primary",
        "temperature": 0.2,
        "description": "pm-workflow primary coordinator"
      },
      "pm_advisor": {
        "mode": "primary",
        "temperature": 0.2,
        "description": "Advisor-only decomposition agent"
      },
      "pm_backend": {
        "mode": "subagent",
        "temperature": 0.2,
        "description": "Backend/plugin/API implementation agent"
      },
      "pm_frontend": {
        "mode": "subagent",
        "hidden": true,
        "temperature": 0.25,
        "description": "Frontend/UI implementation agent"
      },
      "pm_reviewer": {
        "mode": "subagent",
        "hidden": true,
        "temperature": 0.1,
        "description": "QA/code-review and documentation agent"
      },
      "pm_researcher": {
        "mode": "subagent",
        "hidden": true,
        "temperature": 0.3,
        "description": "Research/official docs lookup agent"
      }
    }
  },
  "docs": {
    "storage_mode": "project_scoped",
    "read_legacy": true,
    "write_legacy": false
  },
  "retry": {
    "max_attempts": 2,
    "retryable_actions": [
      "collect-spec",
      "create-design-brief",
      "create-dev-plan",
      "start-development",
      "run-code-review",
      "continue-development"
    ]
  },
  "fallback": {
    "max_attempts": 1,
    "enabled_actions": [
      "collect-spec",
      "create-design-brief",
      "create-dev-plan",
      "start-development",
      "run-code-review",
      "continue-development"
    ],
    "agent_map": {
      "plan": "pm_advisor",
      "build": "pm_advisor",
      "backend": "pm_backend",
      "frontend": "pm_frontend",
      "qa_engineer": "pm_reviewer",
      "writer": "pm_reviewer",
      "researcher": "pm_researcher"
    },
    "chains": {
      "pm_lead": [
        "kr/claude-sonnet-4.5",
        "cx/gpt-5.5"
      ],
      "pm_backend": [
        "cx/gpt-5.5",
        "kr/claude-sonnet-4.5"
      ],
      "pm_frontend": [
        "kr/claude-sonnet-4.5",
        "cx/gpt-5.4"
      ],
      "pm_reviewer": [
        "kr/claude-haiku-4.5"
      ]
    }
  }
}
