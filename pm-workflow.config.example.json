{
  "$schema": "https://unpkg.com/@walke/opencode-pm-workflow@latest/pm-workflow.schema.json",
  "automation": {
    "mode": "observe"
  },
  "permissions": {
    "allow_execute_tools": true,
    "allow_repair_tools": true,
    "allow_release_actions": false
  },
  "confirm": {
    "require_confirm_for_execute": false
  },
  "agents": {
    "enabled": true,
    "default_mode": "subagent",
    "dispatch_map": {
      "pm": "pm_workflow_caocao",
      "plan": "pm_workflow_zhuge",
      "build": "pm_workflow_zhuge",
      "commander": "pm_workflow_zhuge",
      "backend": "pm_workflow_lvbu",
      "frontend": "pm_workflow_frontend",
      "qa_engineer": "pm_workflow_qa",
      "writer": "pm_workflow_writer"
    },
    "definitions": {
      "pm_workflow_caocao": {
        "model": "cx/gpt-5.5",
        "mode": "primary",
        "temperature": 0.2,
        "description": "Cao Cao, pm-workflow primary coordinator",
        "prompt": "你是曹操（Cao Cao），pm-workflow 的主协调 agent。快速压缩需求，确定目标、边界、todo、验收标准与分派路径；随后推进开发、测试与发布摘要。"
      },
      "pm_workflow_zhuge": {
        "model": "kr/claude-sonnet-4.5",
        "mode": "all",
        "temperature": 0.2,
        "description": "Zhuge Liang, advisor-only decomposition agent"
      },
      "pm_workflow_lvbu": {
        "model": "cx/gpt-5.3-codex",
        "mode": "all",
        "temperature": 0.2,
        "description": "Lv Bu, backend/plugin/API implementation agent"
      },
      "pm_workflow_frontend": {
        "model": "antigravity/gemini-3-flash-preview",
        "mode": "all",
        "hidden": true,
        "temperature": 0.25,
        "description": "Frontend/UI implementation agent"
      },
      "pm_workflow_qa": {
        "model": "kr/claude-sonnet-4.5",
        "mode": "all",
        "hidden": true,
        "temperature": 0.1,
        "description": "QA/code-review verification agent"
      },
      "pm_workflow_writer": {
        "model": "kr/claude-haiku-4.5",
        "mode": "all",
        "hidden": true,
        "temperature": 0.3,
        "description": "Documentation and release notes agent"
      }
    }
  },
  "docs": {
    "storage_mode": "project_scoped",
    "read_legacy": true,
    "write_legacy": false
  },
  "retry": {
    "max_attempts": 2,
    "retryable_actions": [
      "collect-spec",
      "create-design-brief",
      "create-dev-plan",
      "start-development",
      "run-code-review",
      "continue-development"
    ]
  },
  "fallback": {
    "max_attempts": 1,
    "enabled_actions": [
      "collect-spec",
      "create-design-brief",
      "create-dev-plan",
      "start-development",
      "run-code-review",
      "continue-development"
    ],
    "agent_map": {
      "plan": "pm_workflow_zhuge",
      "build": "pm_workflow_zhuge",
      "backend": "pm_workflow_lvbu",
      "frontend": "pm_workflow_frontend",
      "qa_engineer": "pm_workflow_qa",
      "writer": "pm_workflow_writer"
    }
  }
}
