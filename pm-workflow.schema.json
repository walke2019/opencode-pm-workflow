{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://unpkg.com/@walke/opencode-pm-workflow@latest/pm-workflow.schema.json",
  "title": "opencode-pm-workflow config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "retry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "retryable_actions": {
          "$ref": "#/$defs/actions"
        }
      }
    },
    "fallback": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_attempts": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "enabled_actions": {
          "$ref": "#/$defs/actions"
        },
        "agent_map": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "chains": {
          "type": "object",
          "description": "运行时模型降级链（ForegroundFallback）。key 为 agent 名（如 commander）或 model id；value 为按优先级排列的备用 model id 列表。当 dispatch 子进程返回限流/超时/上下文溢出/模型不可用错误时，自动按链路切换备用 model，避免无效重试。",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          }
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allow_execute_tools": {
          "type": "boolean"
        },
        "allow_repair_tools": {
          "type": "boolean"
        },
        "allow_release_actions": {
          "type": "boolean"
        },
        "allow_auto_continue": {
          "type": "boolean",
          "description": "0.5.0 起：是否允许 dispatch 完成后自动续跑下一步。默认 false；即便打开仍受 auto_continue.enabled 与 Gate / Confirm 全部约束。"
        }
      }
    },
    "confirm": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "require_confirm_for_execute": {
          "type": "boolean"
        }
      }
    },
    "agents": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "default_mode": {
          "enum": ["primary", "subagent", "all"]
        },
        "dispatch_map": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "properties": {
            "pm": {
              "type": "string"
            },
            "plan": {
              "type": "string"
            },
            "build": {
              "type": "string"
            },
            "qa_engineer": {
              "type": "string"
            },
            "writer": {
              "type": "string"
            },
            "frontend": {
              "type": "string"
            },
            "commander": {
              "type": "string"
            },
            "backend": {
              "type": "string"
            }
          }
        },
        "definitions": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/agent"
          },
          "properties": {
            "commander": {
              "$ref": "#/$defs/agent"
            },
            "advisor": {
              "$ref": "#/$defs/agent"
            },
            "backendcoder": {
              "$ref": "#/$defs/agent"
            },
            "designer": {
              "$ref": "#/$defs/agent"
            },
            "fixer": {
              "$ref": "#/$defs/agent"
            },
            "advisor": {
              "$ref": "#/$defs/agent"
            }
          }
        }
      }
    },
    "automation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "enum": ["off", "observe", "assist", "strict"]
        }
      }
    },
    "auto_continue": {
      "type": "object",
      "additionalProperties": false,
      "description": "0.5.0 起：自动续跑（Auto-continue）受控配置。所有字段都是在 Gate / Permission / Confirm 之上叠加的额外约束；Gate 不通过即停。",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "总开关。默认 false，必须显式打开。"
        },
        "max_steps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "单次链路最大续跑步数（不含原始步）。建议 ≤ 3。"
        },
        "cooldown_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "步骤之间的最小等待毫秒数，避免瞬间烧 token。建议 ≥ 2000。"
        },
        "require_clean_tree": {
          "type": "boolean",
          "description": "开启时只在 git 工作树干净（无未提交改动）时自动续跑。"
        },
        "stop_on_feedback_signal": {
          "type": "boolean",
          "description": "开启时，specialist 输出里出现『停下/不要再/stop/cancel/abort』等用户反馈停止词，立即终止链路。"
        }
      }
    },
    "docs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "storage_mode": {
          "enum": ["legacy", "project_scoped"]
        },
        "read_legacy": {
          "type": "boolean"
        },
        "write_legacy": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "actions": {
      "type": "array",
      "items": {
        "enum": [
          "collect-spec",
          "create-design-brief",
          "create-dev-plan",
          "start-development",
          "run-code-review",
          "prepare-release",
          "continue-development",
          "blocked"
        ]
      },
      "uniqueItems": true
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "model": {
          "type": ["string", "null"]
        },
        "fallback_models": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "mode": {
          "enum": ["primary", "subagent", "all"]
        },
        "hidden": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "top_p": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "steps": {
          "type": "integer",
          "minimum": 1
        },
        "permission": {
          "type": "object",
          "additionalProperties": true
        },
        "disabled": {
          "type": "boolean"
        }
      }
    }
  }
}
